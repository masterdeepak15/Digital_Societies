# Copy this to .env — NEVER commit .env to git
# Run: cp .env.prod.example .env   then edit values

# ── Domain ─────────────────────────────────────────────────────────────────
DOMAIN=societies.athomes.space
JWT_ISSUER=https://societies.athomes.space
JWT_AUDIENCE=digital-societies-clients

# ── Generate strong secrets (run these in terminal) ─────────────────────────
# openssl rand -base64 32
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
JWT_SECRET_KEY=REPLACE_WITH_MIN_32_CHAR_SECRET

# ── MinIO (file storage) ─────────────────────────────────────────────────────
MINIO_ACCESS_KEY=REPLACE_WITH_ACCESS_KEY
MINIO_SECRET_KEY=REPLACE_WITH_SECRET_KEY_MIN_8_CHARS

# ── SMS / OTP (MSG91) ────────────────────────────────────────────────────────
MSG91_API_KEY=REPLACE_WITH_MSG91_API_KEY
