# ──────────────────────────────────────────────────────────────────────────────
# Digital Societies — Environment Configuration
# Copy to .env and fill in your values before running docker compose up
# NEVER commit .env to git (it's in .gitignore)
# ──────────────────────────────────────────────────────────────────────────────

# ── Domain & TLS ──────────────────────────────────────────────────────────────
DOMAIN=society.example.com
WEB_ADMIN_URL=https://society.example.com
API_URL=https://society.example.com/api

# ── Database ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48   (must be >= 32 chars)
JWT_SECRET_KEY=CHANGE_ME_minimum_32_chars_secret_key_here
JWT_ISSUER=https://society.example.com
JWT_AUDIENCE=digital-societies-clients

# ── Object Storage (MinIO) ────────────────────────────────────────────────────
MINIO_ACCESS_KEY=CHANGE_ME_access_key
MINIO_SECRET_KEY=CHANGE_ME_secret_key_min_8_chars

# ── SMS / OTP (MSG91 — India's primary SMS gateway) ───────────────────────────
# https://msg91.com — register, get API key, create OTP template
MSG91_API_KEY=CHANGE_ME_msg91_api_key
MSG91_SENDER_ID=DGSOC

# ── Payments (Razorpay — primary) ─────────────────────────────────────────────
# https://razorpay.com/docs/payments/payment-gateway/
RAZORPAY_KEY_ID=CHANGE_ME_rzp_key_id
RAZORPAY_KEY_SECRET=CHANGE_ME_rzp_secret
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME_rzp_webhook_secret

# ── Payments (Cashfree — failover, optional) ──────────────────────────────────
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=

# ── Notifications ─────────────────────────────────────────────────────────────
# WhatsApp Business API via Gupshup or Meta Business
WHATSAPP_API_KEY=
WHATSAPP_FROM_NUMBER=

# ── A/V Calling ───────────────────────────────────────────────────────────────
# LiveKit (SaaS) — https://livekit.io
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── SMTP (for admin email notifications) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=CHANGE_ME

# ── License (self-host tier) ──────────────────────────────────────────────────
# Obtain from https://digitalsocieties.app/self-host
DS_LICENSE_KEY=community
