# ── Digital Societies — Docker Compose environment variables ──────────────────
# Copy to infra/docker/.env and fill in secrets. Never commit .env.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=ds_admin
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=digital_societies

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=replace_with_a_64_char_random_secret

# ── MSG91 (SMS notifications) ─────────────────────────────────────────────────
MSG91_AUTH_KEY=your_msg91_api_key
MSG91_SENDER_ID=DGSOC
MSG91_TEMPLATE_VISITOR=your_template_id
MSG91_TEMPLATE_PAYMENT=your_template_id

# ── Expo Push Notifications ───────────────────────────────────────────────────
EXPO_ACCESS_TOKEN=your_expo_access_token

# ── OpenTelemetry / Observability ─────────────────────────────────────────────
OTEL_ENDPOINT=http://otel-collector:4317
GRAFANA_PASSWORD=admin

# ── Caddy (reverse proxy) ─────────────────────────────────────────────────────
# Domain pointing to this server (leave localhost for local dev)
DOMAIN=localhost

# ── Web Admin ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_HUB_URL=http://localhost:5000/hubs
NEXT_PUBLIC_MAP_TILE_URL=https://demotiles.maplibre.org/style.json
