# ── Digital Societies — Web Admin environment variables ───────────────────────
# Copy to .env.local and fill in values. Never commit .env.local.

# API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# SignalR hub URL (same host, different path)
NEXT_PUBLIC_HUB_URL=http://localhost:5000/hubs

# Map tile URL for parking nav page (MapLibre GL JS)
# Free public tiles: https://demotiles.maplibre.org/style.json
# Production: use Mapbox, Maptiler, or self-hosted tile server
NEXT_PUBLIC_MAP_TILE_URL=https://demotiles.maplibre.org/style.json

# Application branding (shown in sidebar and tab title)
NEXT_PUBLIC_APP_NAME="Society Admin"

# Sentry DSN (optional — leave blank to disable error tracking)
NEXT_PUBLIC_SENTRY_DSN=
