{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=postgres;Port=5432;Database=digital_societies;Username=ds_app;Password=${POSTGRES_PASSWORD};Include Error Detail=true",
    "Redis":    "redis:6379,abortConnect=false"
  },
  "Jwt": {
    "Issuer":              "https://api.digitalsocieties.app",
    "Audience":            "digital-societies-clients",
    "SecretKey":           "${JWT_SECRET_KEY}",
    "AccessTokenTtlMin":   10,
    "RefreshTokenTtlDays": 30
  },
  "AllowedOrigins": [
    "https://admin.digitalsocieties.app",
    "http://localhost:3000"
  ],
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      { "Endpoint": "POST:/api/v1/auth/otp/send",   "Period": "1m",  "Limit": 3  },
      { "Endpoint": "POST:/api/v1/auth/otp/verify",  "Period": "5m",  "Limit": 10 },
      { "Endpoint": "*",                              "Period": "1s",  "Limit": 10 },
      { "Endpoint": "*",                              "Period": "1m",  "Limit": 100}
    ]
  },
  "Notification": {
    "Sms": {
      "Provider": "msg91",
      "ApiKey":   "${MSG91_API_KEY}",
      "SenderId": "DGSOC"
    }
  },
  "Storage": {
    "Provider":   "minio",
    "Endpoint":   "minio:9000",
    "AccessKey":  "${MINIO_ACCESS_KEY}",
    "SecretKey":  "${MINIO_SECRET_KEY}",
    "BucketName": "digital-societies"
  }
}
